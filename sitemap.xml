---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.url }}{{ site.baseurl }}/</loc><changefreq>weekly</changefreq><priority>1.0</priority></url>
  <url><loc>{{ site.url }}{{ site.baseurl }}/pricing.html</loc><changefreq>weekly</changefreq><priority>0.9</priority></url>
  {% for p in site.pages %}{% if p.url contains 'tutorials' and p.path contains '.md' %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ p.url | replace: '.md', '.html' }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endif %}{% endfor %}
</urlset>
