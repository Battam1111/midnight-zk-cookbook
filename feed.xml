---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}{{ site.baseurl }}/"/>
  <id>{{ site.url }}{{ site.baseurl }}/</id>
  <author>
    <name>Battam1111</name>
    <uri>https://github.com/Battam1111</uri>
  </author>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  {% for f in site.static_files %}{% if f.path contains '/tutorials/' and f.extname == '.md' %}
  <!-- {{ f.path }} -->
  {% endif %}{% endfor %}
  {% assign tutorials = site.pages | where_exp:"p", "p.path contains 'tutorials/'" | sort: "title" %}
  {% for p in tutorials %}
  <entry>
    <title>{{ p.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ site.baseurl }}{{ p.url | replace: '.md', '.html' }}"/>
    <id>{{ site.url }}{{ site.baseurl }}{{ p.url | replace: '.md', '.html' }}</id>
    <updated>{{ p.date | default: site.time | date_to_xmlschema }}</updated>
    <published>{{ p.date | default: site.time | date_to_xmlschema }}</published>
    <summary type="html">{{ p.description | default: p.title | xml_escape }}</summary>
    <author><name>Battam1111</name></author>
    {% if p.ecosystem %}<category term="{{ p.ecosystem }}"/>{% endif %}
  </entry>
  {% endfor %}
</feed>
